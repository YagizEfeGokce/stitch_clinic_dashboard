# Dermdesk Environment Variables
# Copy this file to .env and fill in your values

# ============================
# REQUIRED - Supabase
# ============================
# Get from: https://supabase.com/dashboard/project/[project-id]/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ============================
# OPTIONAL - Sentry Error Tracking
# ============================
# Get from: https://sentry.io/settings/[org]/projects/[project]/keys/
# Create a new project in Sentry: Choose "React" as the platform
VITE_SENTRY_DSN=

# ============================
# OPTIONAL - PostHog Analytics
# ============================
# Get from: https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ============================
# OPTIONAL - Other Services
# ============================
VITE_RESEND_API_KEY=

# ============================
# APP VERSION (Auto-set in CI/CD)
# ============================
VITE_APP_VERSION=1.0.0
